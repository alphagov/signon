<% content_for :title, "Update permissions for #{@application.name}" %>

<% content_for :breadcrumbs,
   render("govuk_publishing_components/components/breadcrumbs", {
     collapse_on_mobile: true,
     breadcrumbs: [
       {
         title: "Dashboard",
         url: root_path,
       },
       {
         title: "GOV.UK apps",
         url: account_applications_path,
       },
       {
         title: "Settings",
         url: account_path,
       }
     ]
   })
%>

<%= render "shared/permissions_forms", {
  current_permissions: @current_permissions,
  new_permission_options: @new_permission_options,
  permissions: @permissions,
  shared_permissions_form_locals: @shared_permissions_form_locals
} %>
